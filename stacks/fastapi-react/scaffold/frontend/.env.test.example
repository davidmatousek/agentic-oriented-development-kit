# Example: copy to .env.test and fill in your test database connection string.
#
# TEST_DATABASE_URL naming requirement:
#   The database name MUST contain "test_" or "_test" (case-insensitive)
#   to pass the fixture's isolation guard. This prevents the E2E suite
#   from accidentally running destructive migrations against your dev DB.
#
# Example valid DSNs:
#   postgresql+asyncpg://postgres:postgres@localhost:5432/myapp_test
#   postgresql+asyncpg://postgres:postgres@localhost:5433/test_myapp
#
# The fixture (frontend/e2e/fixtures.ts) fails fast with a clear error if:
#   (a) TEST_DATABASE_URL is unset or empty
#   (b) TEST_DATABASE_URL equals DATABASE_URL (dev DSN collision)
#   (c) the database name lacks the naming prefix
TEST_DATABASE_URL=

# Optional: override default test ports.
# Defaults: backend 8001 (avoids dev's 8000), frontend 5173 (Vite default).
BACKEND_TEST_PORT=8001
FRONTEND_TEST_PORT=5173

# Optional: override the test-only SECRET_KEY used by the backend subprocess
# during E2E runs. The playwright.config.ts webServer env defaults to a
# test-only value so fresh scaffolds boot without a backend/.env file.
# Set this only if your tests need a specific key (e.g., to match a signed
# fixture token).
# TEST_SECRET_KEY=
