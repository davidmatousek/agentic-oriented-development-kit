# Supabase — project URL and public anon key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase — service role key (server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database — Prisma connection strings
# Use pooled connection for most queries
DATABASE_URL=your-database-url
# Use direct connection for migrations (bypasses connection pooler)
DIRECT_URL=your-direct-url
